---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  CV_META,
  SECTIONS,
  EXPERIENCE,
  EDUCATION,
  LEADERSHIP,
  STANDARDS,
  POLICY,
  CERTIFICATIONS,
  PRESENTATIONS,
  RECOGNITION,
  PUBLICATIONS,
  SKILLS,
} from "@/data/cv";
---

<BaseLayout
  title="Credentials"
  description="Credentials of Omoshola Owolabi — work experience, IEEE standards development, federal AI policy engagement, peer-reviewed publications, and recognition."
  profilePage={true}
>
  <main id="main-content" class="mx-auto w-full max-w-3xl px-4 pb-12">
    <section id="credentials" class="mb-28 mt-8 max-w-3xl">
      <!-- Hero -->
      <div class="mb-10">
        <h1
          class="mb-4 text-4xl leading-tight font-bold tracking-tight sm:text-5xl"
        >
          {CV_META.name}
        </h1>
        <p class="max-w-2xl text-lg leading-relaxed opacity-80">
          {CV_META.descriptor}
        </p>
        <div
          class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm opacity-80"
        >
          <span>{CV_META.location}</span>
          <span aria-hidden="true">·</span>
          <a href={`mailto:${CV_META.email}`} class="hover:text-accent">
            {CV_META.email}
          </a>
        </div>
      </div>

      <!-- Section index -->
      <nav
        aria-label="Sections"
        class="mb-12 border-l-4 pl-6"
        style="border-color: var(--accent);"
      >
        <ul class="grid gap-x-6 gap-y-1.5 text-sm sm:grid-cols-2">
          {
            SECTIONS.map((s) => (
              <li>
                <a href={`#${s.id}`} class="opacity-80 hover:text-accent">
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Work Experience -->
      <h2 id="experience" class="mt-10 mb-4 scroll-mt-24 text-2xl font-bold">
        Work Experience
      </h2>
      <hr />
      <div class="space-y-8">
        {
          EXPERIENCE.map((job) => (
            <div>
              <div class="flex flex-col justify-between gap-x-4 sm:flex-row sm:items-baseline">
                <h3 class="text-lg font-semibold">
                  {job.org ? (
                    <>
                      {job.org}
                      {job.role ? ` — ${job.role}` : ""}
                    </>
                  ) : (
                    job.role
                  )}
                </h3>
                <span class="text-sm whitespace-nowrap italic opacity-70">
                  {job.period}
                </span>
              </div>
              <ul class="mt-3 list-disc space-y-2 pl-5 opacity-80">
                {job.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <!-- Education -->
      <h2 id="education" class="mt-14 mb-4 scroll-mt-24 text-2xl font-bold">
        Education
      </h2>
      <hr />
      <div class="space-y-5">
        {
          EDUCATION.map((ed) => (
            <div>
              <div class="flex flex-col justify-between gap-x-4 sm:flex-row sm:items-baseline">
                <h3 class="text-lg font-semibold">{ed.school}</h3>
                <span class="text-sm whitespace-nowrap italic opacity-70">
                  {[ed.location, ed.date].filter(Boolean).join(" · ")}
                </span>
              </div>
              <p class="mt-1 italic opacity-80">{ed.credential}</p>
            </div>
          ))
        }
      </div>

      <!-- Leadership -->
      <h2 id="leadership" class="mt-14 mb-4 scroll-mt-24 text-2xl font-bold">
        Leadership in AI Governance &amp; Ethics
      </h2>
      <hr />
      <div class="space-y-6">
        {
          LEADERSHIP.map((l) => (
            <div>
              <p class="font-semibold">
                {l.role}
                <span class="font-normal italic opacity-70"> | {l.venue}</span>
              </p>
              {l.detail && <p class="mt-1 opacity-80">{l.detail}</p>}
            </div>
          ))
        }
      </div>

      <!-- International Standards Development -->
      <h2 id="standards" class="mt-14 mb-4 scroll-mt-24 text-2xl font-bold">
        International Standards Development
      </h2>
      <hr />
      <div class="mb-6">
        <div
          class="flex flex-col justify-between gap-x-4 sm:flex-row sm:items-baseline"
        >
          <h3 class="text-lg font-semibold">{STANDARDS.intro.title}</h3>
          <span class="text-sm whitespace-nowrap italic opacity-70">
            {STANDARDS.intro.period}
          </span>
        </div>
        <p class="mt-2 opacity-80">{STANDARDS.intro.detail}</p>
      </div>

      {
        [STANDARDS.workingGroup, STANDARDS.entityBallot, STANDARDS.individualBallot].map(
          (block) => (
            <div class="mt-8">
              <h3 class="mb-4 text-base font-bold italic opacity-90">
                {block.label}
              </h3>
              <div class="space-y-6">
                {block.items.map((c) => (
                  <div>
                    <p class="font-semibold">{c.title}</p>
                    <p class="mt-1 text-sm italic opacity-70">
                      Committee: {c.committee}
                    </p>
                    {c.role && (
                      <p class="text-sm opacity-70">Role: {c.role}</p>
                    )}
                    <p class="text-sm opacity-70">Duration: {c.duration}</p>
                    <p class="mt-1 opacity-80">{c.detail}</p>
                  </div>
                ))}
              </div>
            </div>
          )
        )
      }

      <!-- Policy Engagement -->
      <h2 id="policy" class="mt-14 mb-4 scroll-mt-24 text-2xl font-bold">
        Policy Engagement &amp; Government Initiatives
      </h2>
      <hr />
      <div class="space-y-8">
        {
          POLICY.map((p) => (
            <div>
              <div class="flex flex-col justify-between gap-x-4 sm:flex-row sm:items-baseline">
                <h3 class="text-lg font-semibold">
                  {p.role}
                  <span class="font-normal italic opacity-70"> | {p.body}</span>
                </h3>
                <span class="text-sm whitespace-nowrap italic opacity-70">
                  {p.year}
                </span>
              </div>
              <p class="mt-2 opacity-80">{p.summary}</p>
              <p class="mt-3 font-medium">Key Contributions:</p>
              <ul class="mt-1 list-disc space-y-2 pl-5 opacity-80">
                {p.contributions.map((c) => (
                  <li>{c}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <!-- Certifications -->
      <h2 id="certifications" class="mt-14 mb-4 scroll-mt-24 text-2xl font-bold">
        Certifications
      </h2>
      <hr />
      <ul class="list-disc space-y-2 pl-5 opacity-80">
        {CERTIFICATIONS.map((c) => <li>{c}</li>)}
      </ul>

      <!-- Presentations -->
      <h2 id="presentations" class="mt-14 mb-4 scroll-mt-24 text-2xl font-bold">
        Presentations
      </h2>
      <hr />
      <div class="space-y-5">
        {
          PRESENTATIONS.map((pr) => (
            <div>
              <p class="font-semibold">{pr.title}</p>
              <p class="mt-1 italic opacity-80">{pr.detail}</p>
            </div>
          ))
        }
      </div>

      <!-- Recognition -->
      <h2 id="recognition" class="mt-14 mb-4 scroll-mt-24 text-2xl font-bold">
        Professional Recognition &amp; Membership
      </h2>
      <hr />
      <div>
        <p class="font-semibold">{RECOGNITION.title}</p>
        <p class="mt-1 opacity-80">{RECOGNITION.body}</p>
      </div>

      <!-- Publications -->
      <h2 id="publications" class="mt-14 mb-4 scroll-mt-24 text-2xl font-bold">
        Peer-Reviewed Publications
      </h2>
      <hr />
      <p class="mb-4 font-medium">{PUBLICATIONS.leadAuthorLabel}</p>
      <ol class="list-decimal space-y-4 pl-5">
        {
          PUBLICATIONS.items.map((pub) => (
            <li>
              <span class="font-semibold">{pub.title}</span>
              <span class="italic opacity-70"> | {pub.venue}</span>
              <p class="mt-1 opacity-80">{pub.note}</p>
            </li>
          ))
        }
      </ol>
      <div class="mt-6 border-l-4 pl-6" style="border-color: var(--accent);">
        <p class="font-medium">{PUBLICATIONS.impact}</p>
      </div>

      <!-- Technical Skills -->
      <h2 id="skills" class="mt-14 mb-4 scroll-mt-24 text-2xl font-bold">
        Technical Skills
      </h2>
      <hr />
      <dl class="space-y-3">
        {
          SKILLS.map((s) => (
            <div class="flex flex-col gap-x-3 sm:flex-row">
              <dt class="font-semibold sm:w-56 sm:shrink-0">{s.group}</dt>
              <dd class="opacity-80">{s.items}</dd>
            </div>
          ))
        }
      </dl>
    </section>
  </main>
</BaseLayout>
